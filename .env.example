# Optional: backend port for native dev (npm run dev). Defaults to 3001 if unset — override here
# if that port is already used by another app on your machine (also update the frontend's Vite
# proxy target in frontend/vite.config.js to match).
PORT=

# Optional: UPCitemdb API key for barcode → product name lookup (100 req/day free without key)
UPCITEMDB_KEY=

# Optional: Mistral API key — recommendations feature is disabled when absent
MISTRAL_API_KEY=

# Optional: BGG credentials for auto-login on startup (used by the collection sync feature)
BGG_USERNAME=
BGG_PASSWORD=

# Required as of mid-2025: BGG now requires a Bearer token for XML API2 requests (search,
# collection sync, hot list). Register an app at https://boardgamegeek.com/applications to get
# one. Without it, game search silently falls back to local-only results.
BGG_API_KEY=
